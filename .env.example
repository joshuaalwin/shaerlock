# Copy to .env (gitignored) and fill in. The CLI auto-loads .env from CWD.

# Used by `ai-fw-audit --provider anthropic`. Get from https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Optional override; default is claude-sonnet-4-6.
# AI_FW_AUDIT_ANTHROPIC_MODEL=claude-sonnet-4-6

# Optional Ollama overrides.
# AI_FW_AUDIT_OLLAMA_HOST=http://localhost:11434
# AI_FW_AUDIT_OLLAMA_MODEL=llama3.1:8b
